rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /photos/{photoId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uploadedBy == request.auth.uid;
      allow delete: if request.auth != null
        && (resource.data.uploadedBy == request.auth.uid
            || request.auth.token.role == 'leader');
      allow update: if request.auth.token.role == 'leader';
    }

    match /events/{document=**} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth.token.role == 'leader';
    }

    // Announcements: leader posts, everyone reads
    match /announcements/{document=**} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth.token.role == 'leader';
    }

    // Photo reactions (hearts): any signed-in user, stored as /photos/{id}/reactions/{uid}
    match /photos/{photoId}/reactions/{uid} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && request.auth.uid == uid;
    }

    // Troop members (girls): leader manages, everyone reads
    match /girls/{document=**} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth.token.role == 'leader';
    }

    // Troop-wide settings (e.g. cookie goal): leader manages, everyone reads
    match /troopSettings/{document=**} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth.token.role == 'leader';
    }
  }
}
