rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /photos/{photoId} {
      // Any signed-in user can view photos
      allow read: if request.auth != null;

      // Any signed-in user can upload a photo — must stamp their own uid
      allow create: if request.auth != null
        && request.resource.data.uploadedBy == request.auth.uid;

      // Only the original uploader OR a leader can delete a photo
      allow delete: if request.auth != null
        && (resource.data.uploadedBy == request.auth.uid
            || request.auth.token.role == 'leader');

      // Only leaders can edit (e.g. change caption)
      allow update: if request.auth.token.role == 'leader';
    }

    match /events/{document=**} {
      // All signed-in users can see events; only leaders manage them
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth.token.role == 'leader';
    }
  }
}
